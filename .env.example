# Copy to .env and fill in. Keep .env private:  chmod 600 .env

# Bot token from @BotFather (create a NEW bot; don't reuse Joshua's).
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram chat id. Message @userinfobot to get it.
# The bridge ONLY ever responds to this id.
OWNER_CHAT_ID=

# --- optional overrides (shared) ---
# Directory the Overlord is rooted in (default: your home folder).
# OVERLORD_CWD=/home/user
# Seconds to wait for an Allow/Deny tap before auto-denying (default: 300).
# OVERLORD_PERMISSION_TIMEOUT=300

# Skip the per-action Allow/Deny prompt and auto-approve everything EXCEPT
# off-limits secrets (~/.ssh, ~/.aws, browser profiles, SSH keys, ... — those
# are always denied regardless). Off by default. Truthy: 1/true/yes/on.
# OVERLORD_AUTO_APPROVE=0

# --- brain selection ---
# Which engine drives the Overlord: "claude" (default) or "codex".
# Leave unset / "claude" to keep the live deployed behavior unchanged.
# OVERLORD_BRAIN=claude

# --- Claude brain (used when OVERLORD_BRAIN=claude) ---
# Model alias or full id (default: opus).
# OVERLORD_MODEL=opus

# --- Codex brain (used when OVERLORD_BRAIN=codex) ---
# Requires the Codex CLI (npm i -g @openai/codex) AND `codex login`.
# Path/name of the codex binary (default: "codex" on PATH).
# OVERLORD_CODEX_BIN=codex
# Use a shared local Codex app-server Unix socket. The env name is historical:
# the bridge now talks WebSocket directly to `codex app-server --listen
# unix://PATH`, and the `overlord` launcher connects the TUI with
# `codex --remote unix://PATH`, so bridge-started Codex turns stream through
# the same app-server instead of a private stdio app-server.
# Default: false.
# OVERLORD_CODEX_APP_SERVER_PROXY=false
# Default: /home/user/Projects/overlord-bridge/run/codex-app-server.sock
# OVERLORD_CODEX_APP_SERVER_SOCKET=/home/user/Projects/overlord-bridge/run/codex-app-server.sock
# Codex model id; empty = codex's own default (recommended).
# OVERLORD_CODEX_MODEL=
# Approval policy: untrusted | on-failure | on-request | never (default: on-request).
# OVERLORD_CODEX_APPROVAL_POLICY=on-request
# Sandbox: read-only | workspace-write | danger-full-access (default: read-only).
# The Overlord is rooted at /home/user, so read-only is the safe default; write
# actions are routed to Telegram approval before they run.
# OVERLORD_CODEX_SANDBOX=read-only
# Optional alternate instruction file for Codex Overlord threads. Defaults to
# this repo's AGENTS.md, the canonical shared Claude/Codex instruction file.
# OVERLORD_CODEX_INSTRUCTIONS_FILE=/home/user/Projects/overlord-bridge/AGENTS.md

# --- workers (lighter than the Overlord — they do focused code/task work) ---
# The Overlord dispatches workers via the dispatch/ folder; the bridge runs them
# and pushes the result to your phone when they finish. Brain-agnostic: a worker
# can be claude or codex regardless of which brain the Overlord runs.
# Model for Claude workers (default: sonnet). Alias or full id.
# OVERLORD_WORKER_MODEL=sonnet
# Model for Codex workers (empty = codex's own default).
# OVERLORD_WORKER_CODEX_MODEL=
# Local coding workers should use brain=local-agent for agentic behavior.
# Default Qwen3-Coder-Next runs through on-demand llama.cpp/llama-server;
# Qwen2.5 remains as the local Ollama fallback.
# Dispatch with {"brain":"local-agent","model":"qwen3-coder-next"} or
# {"brain":"local-agent","model":"qwen2.5-coder-14b"}.
# The backend behind local-agent can be llama.cpp, Ollama, Aider, or another
# runner; keep dispatches on brain=local-agent and select the model/backend here.
# OVERLORD_WORKER_LOCAL_AGENT_MODEL=openai/Qwen3-Coder-Next
# OVERLORD_WORKER_LOCAL_AGENT_API_BASE=http://127.0.0.1:1234/v1
# OVERLORD_WORKER_LOCAL_AGENT_OPENAI_API_KEY=overlord-local
# For brain=local-agent with Ollama-style aliases, use Ollama's OpenAI-compatible endpoint.
# OVERLORD_WORKER_LOCAL_AGENT_OLLAMA_API_BASE=http://127.0.0.1:11434/v1
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_BIN=/tank/ai/llama.cpp/build/bin/llama-server
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_MODEL=/tank/ai/models/Qwen3-Coder-Next-UD-TQ1_0.gguf
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_HF_REPO=unsloth/Qwen3-Coder-Next-GGUF:UD-TQ1_0
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_HOST=127.0.0.1
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_PORT=1234
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_THREADS=16
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_BATCH=1024
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_N_CPU_MOE=36
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_CACHE_TYPE_K=q8_0
# OVERLORD_WORKER_LOCAL_AGENT_LLAMACPP_CACHE_TYPE_V=q8_0
# Default local context cap for local-agent workers. For llama.cpp-backed
# qwen3-coder-next, this becomes the per-job server --ctx-size and is
# measured/capped at 256000. Qwen2.5 is separately capped lower.
# OVERLORD_WORKER_LOCAL_AGENT_CONTEXT_TOKENS=256000
# If Ollama reports insufficient memory, retry once at this smaller cap.
# OVERLORD_WORKER_LOCAL_AGENT_MIN_CONTEXT_TOKENS=2048
# Soft cap for backend chat-history summarization when a backend uses one.
# OVERLORD_WORKER_LOCAL_AGENT_CHAT_HISTORY_TOKENS=2048
# Ask Ollama to unload the model after one-shot Ollama worker requests.
# OVERLORD_WORKER_LOCAL_AGENT_KEEP_ALIVE=0
# --- NVIDIA NIM cloud workers (brain=nvidia) ---
# Same agent tool loop as local-agent, pointed at NVIDIA's free
# OpenAI-compatible endpoint (integrate.api.nvidia.com). Get a key at
# build.nvidia.com. Required for brain=nvidia dispatches; the rest defaults.
# OVERLORD_WORKER_NVIDIA_API_KEY=nvapi-...
# Default model (alias or full NIM id; aliases in modules/workers.py):
# deepseek (v4-pro, default), deepseek-flash, kimi, qwen3-next, qwen3.5,
# qwen3.5-397b, gpt-oss, nemotron, minimax, mistral, llama. Per-dispatch
# override: {"brain":"nvidia","model":"kimi"}. Task-type selection hints
# live in CAPABILITIES.md ("NVIDIA model selection").
# OVERLORD_WORKER_NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
# OVERLORD_WORKER_NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# --- engine gas gauge + preference router (overlord gas / recommend_engine) ---
# The gauge probes each dispatchable engine (claude, nvidia, codex, local-agent)
# before dispatch and reuses the nvidia/local-agent endpoint keys above plus the
# Claude usage source and ~/.codex/auth.json. Main shared tuning knob:
# at/above this 5-hour usage %, Claude is reserve gas. The near-limit handoff
# hook uses this same env; the router derives reserve gas as 100 - this value.
# OVERLORD_CLAUDE_HANDOFF_USAGE_PERCENT=85
# Block Claude dispatch when the 5-hour session cap has less than this many
# percent gas left (default 5). This is the absolute hard floor.
# OVERLORD_ENGINE_CLAUDE_GAS_FLOOR=5
# Kill-switch: force Codex to 'unavailable' in the gauge when you know it's dead
# (Codex is intermittent-but-credited, so it is polled by default, not retired).
# OVERLORD_ENGINE_CODEX_DISABLED=false
# Cache NVIDIA GET /v1/models during normal gas checks. Active per-model POST
# smoke tests are not part of normal gas; worker reports feed model gas instead.
# OVERLORD_NVIDIA_CATALOG_CACHE_TTL=300

# Append terminal worker completions/failures/timeouts into the active Overlord
# conversation when the brain supports it. Codex app-server uses
# thread/inject_items; Claude currently falls back to Telegram + audit files.
# Default: true.
# WORKER_REPORT_TO_THREAD=true
# Also start a real tagged Codex app-server turn after a terminal worker report,
# producing a visible assistant status message in the active bridge Codex thread.
# The report turn is guarded so it does not approve actions, dispatch workers,
# or recurse. For live TUI visibility, run Codex through the shared Unix socket
# above; `thread/inject_items` alone is durable history, not visible UI. Default: false.
# WORKER_REPORT_VISIBLE_TURN=false
# Durable audit store for accepted/started/terminal worker status. Relative
# paths are resolved under this repo. Default: worker_reports/
# WORKER_REPORT_DIR=worker_reports
# Tail sizes are capped and common token/password forms are redacted.
# WORKER_REPORT_TAIL_CHARS=4000
# WORKER_TELEGRAM_TAIL_CHARS=12000
# WORKER_REPORT_EVENTS_MAX_BYTES=1048576

# --- fetch relay (modules/fetch_relay.py, own service: overlord-fetch-relay) ---
# Localhost-only headless-Chromium fetch endpoint for sites the brains' own
# WebFetch domain-blocks or that bot-wall plain curl. GET /fetch?url=<url>.
# Must stay loopback; the process refuses to start on anything else so it can
# never become an open proxy.
# FETCH_RELAY_HOST=127.0.0.1
# FETCH_RELAY_PORT=8791
# Per-fetch navigation timeout in seconds (hard wall-clock cap is 2x this).
# FETCH_RELAY_TIMEOUT_SECONDS=20
# Max concurrent browser pages.
# FETCH_RELAY_MAX_CONCURRENCY=3
# Max characters returned for extracted text / raw HTML.
# FETCH_RELAY_MAX_CHARS=200000

# Live terminal delivery (dual delivery alongside Telegram, brain-neutral): the
# `overlord` launcher runs the interactive brain in a tmux session with a
# second, passive pane that tails this feed file, so worker reports appear in
# the live terminal the instant they land. Default: true.
# WORKER_REPORT_CLI_FEED=true
# WORKER_REPORT_CLI_FEED_PATH=worker_reports/cli_feed.log
# Opt-in, best-effort: also type the report into the live brain's tmux pane as
# a real turn (tmux send-keys), so the brain reads it in-context. Only fires
# when the pane's prompt line is confirmed idle (never overwrites something
# Ben is mid-typing). Default: false.
# WORKER_REPORT_TERMINAL_INJECT=false
# tmux session the above two target. Default: overlord-<brain>, matching the
# `overlord` launcher.
# WORKER_REPORT_TMUX_SESSION=overlord-claude

# --- Overlord email sender (overlord-email helper, Gmail SMTP) ---
# Required only if you use the `overlord-email` helper. Generate a Google App
# Password (not your login password) at https://myaccount.google.com/apppasswords.
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
